{
  "openapi": "3.0.0",
  "info": {
    "title": "Finance Dashboard API",
    "version": "1.0.0",
    "description": "API for managing financial records and RBAC"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    { "bearerAuth": [] }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
               "schema": { "type": "object", "properties": { "email": { "type": "string" }, "password": { "type": "string" }, "role": { "type": "string", "enum": ["Viewer", "Analyst", "Admin"] } } }
            }
          }
        },
        "responses": {
          "201": { "description": "User created" }
        }
      }
    },
    "/api/records": {
      "post": {
        "summary": "Create record (Admin Only)",
        "responses": { "201": { "description": "Record Created" } }
      },
      "get": {
        "summary": "List records with cursor pagination (Analyst, Admin)",
        "responses": { "200": { "description": "Paginated list" } }
      }
    },
    "/api/dashboard/summary": {
      "get": {
        "summary": "Get aggregate financials (Analyst, Admin)",
        "responses": { "200": { "description": "Totals and Trends" } }
      }
    }
  }
}
